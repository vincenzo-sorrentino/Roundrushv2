{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Roundrush Spec Frontmatter",
  "type": "object",
  "required": [
    "id",
    "domain",
    "feature",
    "status",
    "owner",
    "prototype_route",
    "figma_url",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)+$" },
    "domain": { "type": "string" },
    "feature": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["draft", "in_review", "approved", "implemented", "archived"]
    },
    "owner": { "type": "string" },
    "prototype_route": { "type": "string", "pattern": "^/" },
    "figma_url": { "type": "string", "pattern": "^https://" },
    "updated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": true
}
